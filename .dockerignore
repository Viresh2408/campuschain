*.pptx
*.ppt

# Python scripts (not needed in container)
*.py
__pycache__
*.pyc

# Editor and OS files
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Test files
*.test.js
*.spec.js
__tests__

# Documentation
README.md
campuschain_presentation_script.md

# Deployment scripts (not needed inside container)
deploy/
